{{#*inline 'common-header'}}
  <div class="pta-header-detail pta-item-quantity">Quantity</div>
{{/inline}}

{{#*inline 'equipment-header'}}
  <div class="pta-header-detail pta-equip-state">Equipped</div>
  <div class="pta-header-detail pta-item-quantity">Quantity</div>
{{/inline}}

<div class="pta-tab flexcol flex-gap-l">
  <div class="flexrow flex-gap-l">
    <div class="pta-search-container flexlarge flexrow" data-search="item">
      <div class="pta-search-wrap">
        <i class="fas fa-magnifying-glass"></i>
        <input type="text" class="pta-search-input flex" placeholder="PTA.Placeholder.SearchInventory">
      </div>
      <ul class="flexrow flexshrink flex-nowrap flex-gap-s">
        <li>
          <button class="pta-clear-button" data-action="clear">
            <i class="fas fa-x"></i>
          </button>
        </li>
        <li>
          <button class="pta-clear-button" data-action="sort">
            <i class="fas fa-arrow-down-short-wide"></i>
          </button>
        </li>
      </ul>
    </div>
    <div class="flex">{{systemFieldGroup system 'money'}}</div>
  </div>
  <div class="flexcol pta-inventory flex-gap-l flex">
    {{#each itemTypes}}
      {{#if (not (or (eq @key 'base')  (eq @key 'move') (eq @key 'feature')))}}
        <div class="pta-bag pta-item-list collapsible pta-{{@key}}-list" data-list="{{@key}}">
          <div class="pta-item-list-header" data-action="collapse">
            <div class="pta-header-name">
              <a class="flexshrink">
                <i class="fas fa-caret-down"></i>
              </a>
              <div>{{@key}}</div>
            </div>
            {{#if (eq @key 'equipment')}}
              {{> 'equipment-header'}}
            {{else}}
              {{> 'common-header'}}
            {{/if}}
            <div class="pta-item-controls">
              <button class="pta-clear-button" data-action="create">
                <i class="fas fa-plus"></i>
              </button>
            </div>
          </div>
          <div class="collapsible-content">
            <div class="wrapper">
              <ol class="pta-item-entries">
                {{#each this as | item |}}
                  {{> "pta.list-item" item=item isEditMode=@root.isEditMode isPlayMode=@root.isPlayMode}}
                {{/each}}
              </ol>
            </div>
          </div>
        </div>
      {{/if}}
    {{/each}}
  </div>
</div>